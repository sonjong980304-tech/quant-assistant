# ===== LLM Provider =====
# "ollama" | "openai"
LLM_PROVIDER=openai

# --- OpenAI ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# 권장: SQL 생성=gpt-5.4-mini(기본), Judge=gpt-5.5
OPENAI_MODEL=gpt-5.4-mini
OPENAI_MODEL_SQL=gpt-5.4-mini
OPENAI_MODEL_JUDGE=gpt-5.5
# OpenAI API base (옵션, Azure/프록시용)
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b

# ===== OpenDART =====
# https://opendart.fss.or.kr 에서 발급. 미발급 시 더미 데이터로 동작.
DART_API_KEY=

# ===== DB =====
DB_PATH=data/market.db

# ===== KRX 정보데이터시스템 (업종분류 로그인용) =====
# https://data.krx.co.kr 회원가입 계정. 미설정 시 pykrx의 업종분류 조회(get_market_sector_classifications)가
# 로그인 필요 엔드포인트라 403/LOGOUT으로 실패한다.
KRX_ID=
KRX_PW=

# ===== LangSmith (에이전트별 토큰/비용 트레이싱) =====
# https://smith.langchain.com 에서 API 키 발급. 미설정 시 트레이싱 비활성(기존 동작과 동일).
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=dart-text2sql-wiki

# ===== Slack (크롤러 실패/누락 알림) =====
# Slack Incoming Webhook URL. 미설정 시 알림만 조용히 스킵(수집 자체는 계속 동작).
SLACK_WEBHOOK_URL=

# ===== ngrok (외부 접속 터널: start_server.sh / show_url.sh 사용) =====
NGROK_USERNAME=
NGROK_PASSWORD=
# 미설정 시 ngrok 임시 도메인 사용(재시작마다 URL 변경)
NGROK_DOMAIN=
